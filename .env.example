# =============================================================================
# Backend Analisador Financeiro — Variáveis de Ambiente
# =============================================================================
# CUIDADO: Nunca commite o arquivo .env real. Apenas este .env.example.
# Copie este arquivo para .env e preencha com seus valores reais.
# =============================================================================

# --- Pluggy.ai Credentials ---
# Obtenha em: https://dashboard.pluggy.ai
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=

# --- Database Encryption ---
# Chave Fernet para criptografia de campos sensíveis (PII) no banco.
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DB_ENCRYPTION_KEY=

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Sync ---
# Intervalo em minutos para sincronização automática (0 = desabilitado)
SYNC_INTERVAL_MINUTES=0
